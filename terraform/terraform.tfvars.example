project_name = "sre-assignment"
environment  = "dev"
region       = "eu-central-1"

# Optional explicit name; leave empty to auto-generate from project/environment.
cluster_name = ""

vpc_cidr               = "10.0.0.0/16"
az_count               = 2
availability_zones     = []
enable_nat_gateway     = true
single_nat_gateway     = true
one_nat_gateway_per_az = false

kubernetes_version                   = "1.32"
cluster_endpoint_public_access       = false
cluster_endpoint_private_access      = true
cluster_endpoint_public_access_cidrs = []

node_group_name         = "default"
node_instance_types     = ["t3.medium"]
node_capacity_type      = "ON_DEMAND"
node_group_min_size     = 4
node_group_max_size     = 4
node_group_desired_size = 4
node_group_disk_size    = 20

# Optional demo EC2 fleet for Ansible testing (default: disabled)
ubuntu_instance_count = 0
amazon_linux_instance_count = 0
demo_instance_type    = "t3.micro"
demo_key_name         = ""
demo_ssh_cidrs        = []

# Optional explicit AMI overrides
ubuntu_ami_id = ""
amazon_linux_ami_id = ""

tags = {
  Owner = "platform-team"
}
